# Loaded inside Apptainer by launch_sgl.sh (Apptainer -C strips host env vars).

# Human-in-the-loop codebook review after high-level generation (upload v1 → wait → refine).
export GT_CODEBOOK_REVIEW=0
export GT_CODEBOOK_REVIEW_MODE=manual

# Upload final pipeline artifacts to Supabase after the report step.
export UPLOAD_TO_SUPABASE=0

# Study identifier for codebook_reviews rows and pipeline_runs.
export PIPELINE_SLUG=default

# Qualitative codebook enrichment (definition / inclusion / exclusion / examples).
# 1 = run after refine + after meta-themes (default ON).
# 0 = skip (faster runs, legacy behavior).
export GT_QUALITATIVE_ENRICHMENT=1

# Parallel workers for cluster and dimension enrichment LLM calls.
export GT_ENRICH_WORKERS=4
